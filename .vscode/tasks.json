{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --config Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake -S ${workspaceFolder} -B ${workspaceFolder}/build -G \"MinGW Makefiles\" -DCMAKE_BUILD_TYPE=Debug",
            "group": "build",
            "presentation": {
                "reveal": "always"
            }
        }
    ]
}